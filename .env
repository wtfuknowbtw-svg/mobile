# Local Development Configuration
# This file is used for local development to point to your local backend server
# instead of the production Vercel backend.

# EXPO_PUBLIC_API_URL should point to your local backend running on port 3000
# Replace YOUR_LOCAL_IP with your actual local IP address

# HOW TO FIND YOUR LOCAL IP:
# Windows: Open Command Prompt and run "ipconfig" -> Look for "IPv4 Address"
# Mac: Open Terminal and run "ifconfig" -> Look for "en0" or "en1" -> Look for "inet"
# Linux: Open Terminal and run "ip addr" -> Look for "inet" under your main network interface

# Example formats:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api
# EXPO_PUBLIC_API_URL=http://10.0.0.5:3000/api
# EXPO_PUBLIC_API_URL=http://172.16.0.10:3000/api

# TEMPORARILY USING PRODUCTION BACKEND:
EXPO_PUBLIC_API_URL=https://apnabackend-theta.vercel.app/api

# To use local backend, replace the line above with your actual local IP:
# EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:3000/api

# Note: If EXPO_PUBLIC_API_URL is not set, the app will fall back to:
# https://apnabackend-theta.vercel.app/api (production backend)
