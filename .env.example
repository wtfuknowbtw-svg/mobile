# Environment Variables Example
# Copy this file to .env and fill in your actual values

# Local Development API URL
# Point to your local backend server (port 3000)
# Find your local IP using:
#   Windows: ipconfig -> look for "IPv4 Address"
#   Mac/Linux: ifconfig or ip addr -> look for "inet" address
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:3000/api

# Production fallback (used if EXPO_PUBLIC_API_URL is not set)
# https://apnabackend-theta.vercel.app/api
